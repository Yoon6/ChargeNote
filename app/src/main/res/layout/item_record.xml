<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_m"
    android:layout_marginVertical="@dimen/margin_s"
    style="?attr/materialCardViewElevatedStyle"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_efficiency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_l"
            android:layout_marginVertical="@dimen/margin_m"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="@dimen/record_item_efficiency"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintEnd_toStartOf="@id/tv_date"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="5.5Km/kWh" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_l"
            app:layout_constraintTop_toTopOf="@id/tv_efficiency"
            app:layout_constraintBottom_toBottomOf="@id/tv_efficiency"
            app:layout_constraintStart_toEndOf="@id/tv_efficiency"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="2025-05-04" />

        <TextView
            android:id="@+id/tv_trip_mileage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_s"
            app:layout_constraintEnd_toEndOf="@+id/tv_efficiency"
            app:layout_constraintStart_toStartOf="@id/tv_efficiency"
            app:layout_constraintTop_toBottomOf="@id/tv_efficiency"
            tools:text="300km" />

        <TextView
            android:id="@+id/tv_totalAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_s"
            android:layout_marginBottom="@dimen/margin_m"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/tv_trip_mileage"
            app:layout_constraintStart_toStartOf="@id/tv_trip_mileage"
            app:layout_constraintTop_toBottomOf="@id/tv_trip_mileage"
            tools:text="30,000원" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
